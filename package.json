{
  "workspaces": [
    "packages/*",
    "play",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "test:coverage": "vitest --coverage",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:shared": "tsx scripts/buildShared.ts",
    "build:component": "tsx scripts/buildComponent.ts",
    "build": "tsx scripts/build.ts",
    "prepare": "husky",
    "commit": "git-cz",
    "changeset": "changeset",
    "version": "changeset version",
    "exit": "changeset pre exit",
    "alpha": "changeset pre enter alpha"
  },
  "dependencies": {
    "@vueuse/core": "catalog:",
    "vue": "catalog:"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tsdown/css": "^0.21.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "4.1.2",
    "@vue/test-utils": "^2.4.6",
    "commitizen": "^4.3.1",
    "cz-git": "^1.12.0",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.12",
    "rolldown-plugin-dts": "^0.23.2",
    "sass-embedded": "^1.98.0",
    "tinyglobby": "^0.2.15",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "unplugin-vue": "^7.1.1",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,css,scss,md,json}": [
      "oxlint --fix",
      "oxfmt --write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  },
  "packageManager": "pnpm@10.32.1"
}